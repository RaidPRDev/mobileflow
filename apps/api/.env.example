NODE_ENV=development
PORT=4000
HOST=127.0.0.1

# CORS — comma-separated list of origins allowed to call the API
WEB_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,tauri://localhost

# Postgres (matches infra/.docker/dev.yml)
DATABASE_URL=postgres://mobileflow:mobileflow@127.0.0.1:5432/mobileflow

# Session cookie signing key (rotate periodically). 32+ random bytes hex.
COOKIE_SECRET=change-me-please-32-bytes-of-random-hex

# Bootstrap superadmin: when SUPERADMIN_EMAIL is set, `db:seed` ensures a user
# with this email exists, has isSuperadmin=true, and owns the "mf-admin" org on
# the unlimited plan. SUPERADMIN_PASSWORD is only used when creating the user
# for the first time (defaults to "mobileflow" if unset). Override per-env.
SUPERADMIN_EMAIL=admin@mobileflow.local
SUPERADMIN_PASSWORD=mobileflow

# OAuth — leave blank to disable a provider. Redirect URIs at the provider must
# point to <API_BASE>/api/auth/oauth/<provider>/callback (and same path with /git/<provider>/callback for git connections).
API_BASE_URL=http://127.0.0.1:4000
WEB_BASE_URL=http://127.0.0.1:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign-in scope only (read:user user:email). Use a SECOND GitHub OAuth App for git connections (repo scope).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GITHUB_GIT_CLIENT_ID=
GITHUB_GIT_CLIENT_SECRET=

# 32-byte hex used to encrypt OAuth tokens, env-var values, certificate blobs.
TOKEN_ENC_KEY=

# --- Linux build host (Android + Web) ---
# Leave LINUX_BUILD_HOST blank to keep using the StubRunner.
LINUX_BUILD_HOST=
LINUX_BUILD_PORT=22
LINUX_BUILD_USER=root
# Either provide a key path on the API box, or paste the private key (one of these is required).
LINUX_BUILD_SSH_KEY_PATH=
LINUX_BUILD_SSH_KEY=
# Where build sandboxes live on the host: <base>/<orgId>/<buildId>/
LINUX_BUILD_REMOTE_BASE=/root/RaidX/Clients
# Where artifacts are copied for download.
LINUX_BUILD_DOWNLOADS_BASE=/root/RaidX/downloads
# Public URL prefix mapped to LINUX_BUILD_DOWNLOADS_BASE by the file server (e.g. xbuilds nginx).
LINUX_BUILD_DOWNLOADS_BASE_URL=https://xbuilds.raidpr.com
# Docker image used for Android builds — must already exist on the host.
LINUX_BUILD_ANDROID_IMAGE=raidx-android-builder:latest
# Tools dir on the host, must contain main_build.sh used by the script.
LINUX_BUILD_ANDROID_TOOLS=/root/RaidX/Tools/android

# --- Mac build host (iOS) ---
# Leave MAC_BUILD_HOST blank to keep using StubRunner for iOS.
# SSH KEY AUTH ONLY — no sshpass / no plaintext password.
MAC_BUILD_HOST=
MAC_BUILD_PORT=22
MAC_BUILD_USER=
MAC_BUILD_SSH_KEY_PATH=
MAC_BUILD_SSH_KEY=
# Per-build sandbox: <base>/<orgId>/<buildId>/
MAC_BUILD_REMOTE_BASE=/Users/build/RaidX/Clients
# Where artifacts get copied (served by something fronting it like nginx).
MAC_BUILD_DOWNLOADS_BASE=/Users/build/RaidX/downloads
MAC_BUILD_DOWNLOADS_BASE_URL=https://xbuilds.raidpr.com
# main_build.sh on the Mac (the existing RaidX iOS pipeline).
MAC_BUILD_TOOLS=/Users/build/RaidX/Tools

# --- Linux Web runner ---
# Reuses LINUX_BUILD_* host config above.
LINUX_BUILD_WEB_IMAGE=node:20-alpine
# Build command run inside the container (sh -lc).
LINUX_BUILD_WEB_COMMAND=npm ci && npm run build
# Folder that gets zipped as the artifact.
LINUX_BUILD_WEB_DIST_DIR=dist

# --- Stripe ---
# Leave STRIPE_SECRET_KEY blank to disable billing endpoints.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Map plan ids to Stripe Price IDs (paid plans only).
STRIPE_PRICE_BOHIO=
STRIPE_PRICE_YUCAYEQUE=
STRIPE_PRICE_CACIQUE=

