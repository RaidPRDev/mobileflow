    "@mobileflow/shared": "workspace:*",
    "@node-rs/argon2": "^1.8.3",
    "drizzle-orm": "^0.31.2",
    "fastify": "^4.27.0",
    "google-auth-library": "^9.10.0",
    "pino": "^9.1.0",
    "pino-pretty": "^11.2.1",
    "postgres": "^3.4.4",
    "ssh2": "^1.15.0",
    "stripe": "^16.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/ssh2": "^1.15.0",
    "chokidar": "^3.6.0",
