{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MobileFlow",
  "version": "0.0.0",
  "identifier": "com.raidpr.mobileflow",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm --filter @mobileflow/web dev",
    "beforeBuildCommand": "pnpm --filter @mobileflow/web build"
  },
  "app": {
    "windows": [
      {
        "title": "MobileFlow",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
