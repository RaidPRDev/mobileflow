{
  "name": "mobileflow",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @mobileflow/web dev",
    "dev:api": "pnpm --filter @mobileflow/api dev",
    "dev:docs": "pnpm --filter @mobileflow/docs dev",
    "build:docs": "pnpm --filter @mobileflow/docs build",
    "dev:db": "docker-compose -f infra/.docker/dev.yml up -d",
    "dev:db:down": "docker-compose -f infra/.docker/dev.yml down",
    "dev:db:reset": "docker-compose -f infra/.docker/dev.yml down -v && docker-compose -f infra/.docker/dev.yml up -d",
    "dev:up": "node infra/scripts/dev-up.mjs",
    "dev:nuke": "node infra/scripts/dev-nuke.mjs",
    "deploy:build-scripts": "node infra/scripts/deploy-build-scripts.mjs",
    "deploy:build-scripts:android": "node infra/scripts/deploy-build-scripts.mjs --android",
    "deploy:build-scripts:ios": "node infra/scripts/deploy-build-scripts.mjs --ios",
    "db:push": "pnpm --filter @mobileflow/api db:push",
    "db:seed": "pnpm --filter @mobileflow/api db:seed",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rimraf node_modules"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5"
  }
}
